# Cloudflare Pages - Cache headers
# Landing pages: always fetch the latest HTML.
/
  Cache-Control: no-store, max-age=0, s-maxage=0, must-revalidate

/index.html
  Cache-Control: no-store, max-age=0, s-maxage=0, must-revalidate

/register.html
  Cache-Control: no-store, max-age=0, s-maxage=0, must-revalidate

/*.html
  Cache-Control: no-store, max-age=0, s-maxage=0, must-revalidate

# Legacy cleanup service worker: never cache.
/sw.js
  Cache-Control: no-cache, no-store, max-age=0, s-maxage=0, must-revalidate

# Static assets: store locally but revalidate, so deploys do not need manual version bumps.
/css/*
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate

/icons/*
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate

/images/*
  Cache-Control: public, max-age=0, s-maxage=0, must-revalidate
